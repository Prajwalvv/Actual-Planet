rules_version = '2';

// ═══════════════════════════════════════════════════════
// RYLVO Firestore Security Rules
//
// Architecture: CLIENT = READ-ONLY, SERVER = ALL WRITES
// All writes go through the API server using Admin SDK,
// which bypasses these rules entirely.
// These rules only affect direct client-side Firestore access.
// ═══════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ───────────────────────────────
    // Authenticated users can READ their own doc only.
    // ALL writes handled by server (Admin SDK).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Server-only via Admin SDK

      // ─── API Keys (subcollection) ──────────
      match /apiKeys/{keyId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Server-only
      }

      // ─── Usage (subcollection) ─────────────
      match /usage/{monthId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Server-only
      }

      // ─── Request Logs (subcollection) ──────
      match /requestLogs/{logId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Server-only
      }

      // ─── Invoices (subcollection) ──────────
      match /invoices/{invoiceId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Server-only
      }
    }

    // ─── Reports (shared, read-only) ─────────
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Discoveries (shared, read-only) ─────
    match /discoveries/{discoveryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Swarm Instances (server-only) ───────
    match /swarmInstances/{instanceId} {
      allow read, write: if false;
    }

    // ─── Deny everything else ────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
