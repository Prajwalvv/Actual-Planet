{
  "name": "@rylvo/swarm-core",
  "version": "0.1.0",
  "description": "Stigmergic computing engine — swarm intelligence from non-intelligent agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/swarm-api.ts",
    "map": "ts-node src/swarm-api.ts",
    "api": "ts-node src/swarm-api.ts",
    "site:dev": "npm --prefix public/site run dev",
    "start": "node dist/swarm-api.js",
    "trace:validator": "SWARM_AGENT_TRACE=1 ts-node src/run-validator-trace.ts",
    "trace:policy": "SWARM_POLICY_TRACE=1 ts-node src/run-policy-trace.ts",
    "test:e2e": "ts-node src/run-e2e-test.ts",
    "deploy:hosting": "bash scripts/deploy-hosting.sh",
    "deploy:cloudrun": "bash scripts/deploy-cloudrun.sh",
    "deploy:firestore": "bash scripts/deploy-firestore.sh",
    "deploy:all": "npm run build && npm run deploy:cloudrun && npm run deploy:firestore && npm run deploy:hosting",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/ws": "^8.18.1",
    "cheerio": "^1.0.0-rc.12",
    "express": "^5.2.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "ioredis": "^5.9.3",
    "puppeteer": "^24.37.3",
    "uuid": "^9.0.0",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
